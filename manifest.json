{
  "manifest_version": 3,
  "name": "TLDR PR — Auto-View Test Files",
  "version": "1.0.0",
  "description": "Automatically marks test files as 'Viewed' on GitHub pull request reviews.",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*/files*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
